{% extends 'base.html.twig' %}

{% block title %}Nouvelle commande PrintSmarter{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        .product-item {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            position: relative;
        }
        .product-item .btn-remove-product {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
        }
        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid #0d6efd;
            padding-bottom: 0.4rem;
            margin-bottom: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex align-items-center mb-4">
                <span class="fs-2 me-2">🖨️</span>
                <h1 class="h3 mb-0">Commande PrintSmarter</h1>
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

            <div class="card mb-4">
                <div class="card-header fw-semibold">📋 Informations générales</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">{{ form_label(form.order_id_client) }}</label>
                            {{ form_widget(form.order_id_client) }}
                            {{ form_errors(form.order_id_client) }}
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ form_label(form.shipping_code) }}</label>
                            {{ form_widget(form.shipping_code) }}
                            {{ form_errors(form.shipping_code) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">📦 Adresse de livraison</div>
                        <div class="card-body">
                            {% for field in form.shipping_address %}
                                <div class="mb-2">
                                    <label class="form-label small mb-1">{{ form_label(field) }}</label>
                                    {{ form_widget(field) }}
                                    {{ form_errors(field) }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">↩️ Adresse de retour</div>
                        <div class="card-body">
                            {% for field in form.return_address %}
                                <div class="mb-2">
                                    <label class="form-label small mb-1">{{ form_label(field) }}</label>
                                    {{ form_widget(field) }}
                                    {{ form_errors(field) }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header fw-semibold">📚 Produits</div>
                <div class="card-body">
                    <div id="products-collection"
                         data-prototype="{{ form_widget(form.products.vars.prototype)|e('html_attr') }}">

                        {% for productForm in form.products %}
                            <div class="product-item">
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-product">✕</button>
                                <p class="section-title">Produit {{ loop.index }}</p>
                                <div class="row g-2">
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.project_name) }}</label>
                                        {{ form_widget(productForm.project_name) }}
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.product_id_client) }}</label>
                                        {{ form_widget(productForm.product_id_client) }}
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.product_id) }}</label>
                                        {{ form_widget(productForm.product_id) }}
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.pages) }}</label>
                                        {{ form_widget(productForm.pages) }}
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.file_cover) }}</label>
                                        {{ form_widget(productForm.file_cover) }}
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label small">{{ form_label(productForm.file_content) }}</label>
                                        {{ form_widget(productForm.file_content) }}
                                    </div>
                                </div>
                                {{ form_errors(productForm) }}
                            </div>
                        {% endfor %}
                    </div>

                    <button type="button" id="add-product" class="btn btn-outline-primary btn-sm mt-2">
                        ＋ Ajouter un produit
                    </button>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    🚀 Envoyer la commande
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const collection = document.getElementById('products-collection');
            let index = collection.querySelectorAll('.product-item').length;

            function addProduct() {
                const prototype = collection.dataset.prototype;
                const newForm = prototype.replace(/__name__/g, index);
                const div = document.createElement('div');
                div.classList.add('product-item');
                div.innerHTML =
                    '<button type="button" class="btn btn-sm btn-outline-danger btn-remove-product">✕</button>' +
                    '<p class="section-title">Produit ' + (index + 1) + '</p>' +
                    '<div class="row g-2">' + newForm + '</div>';

                // Wrap each field in Bootstrap column
                div.querySelectorAll('input, select, textarea').forEach(function (el) {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('col-md-7', 'mb-2');
                    el.classList.add('form-control');
                    el.parentNode.insertBefore(wrapper, el);
                    wrapper.appendChild(el);
                });

                collection.appendChild(div);
                index++;
                bindRemove(div.querySelector('.btn-remove-product'));
            }

            function bindRemove(btn) {
                btn.addEventListener('click', function () {
                    btn.closest('.product-item').remove();
                });
            }

            document.getElementById('add-product').addEventListener('click', addProduct);

            collection.querySelectorAll('.btn-remove-product').forEach(bindRemove);
        });
    </script>
{% endblock %}

