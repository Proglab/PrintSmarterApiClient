{% extends 'base.html.twig' %}

{% block title %}Commande envoyée avec succès{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="alert alert-success d-flex align-items-center gap-3 mb-4">
                <span class="fs-3">✅</span>
                <div>
                    <h4 class="alert-heading mb-1">Commande envoyée avec succès !</h4>
                    <p class="mb-0">La commande <strong>{{ order.order_id_client }}</strong> a bien été transmise à PrintSmarter.</p>
                </div>
            </div>

            {% if result %}
            <div class="card mb-4">
                <div class="card-header fw-semibold">📨 Réponse de l'API</div>
                <div class="card-body">
                    <pre class="bg-light p-3 rounded mb-0" style="font-size: 0.85rem;">{{ result|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                </div>
            </div>
            {% endif %}

            <a href="{{ path('print_smarter_order_new') }}" class="btn btn-primary">
                ＋ Créer une nouvelle commande
            </a>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

