{
    "name": "proglab/print-smarter-api-client",
    "description": "Client for the Print Smarter API, a service that allows you to easily print PDF documents on demand.",
    "type": "symfony-bundle",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Proglab\\PrintSmarterApiClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Fabrice Gyre",
            "email": "info@proglab.com"
        }
    ],
    "require": {
        "symfony/flex": "^2.8",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "^7.4",
        "symfony/object-mapper": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/form": "^7.4",
        "symfony/validator": "^7.4"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    }
}
